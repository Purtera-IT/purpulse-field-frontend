+    hoisted.emitFeedbackEvent.mockResolvedValue(undefined);
+    hoisted.fetchJobContextForArtifactEvent.mockResolvedValue({ site_id: 's1' });
+    hoisted.jobUpdate.mockResolvedValue({});
