diff --git a/src/lib/telemetry/artifactQcEvents.js b/src/lib/telemetry/artifactQcEvents.js
new file mode 100644
index 0000000..2d00b82
--- /dev/null
+++ b/src/lib/telemetry/artifactQcEvents.js
@@ -0,0 +1,74 @@
+
+import { postTelemetry, queueTelemetry } from './ingestionClient';
+
+function baseEnvelope(eventName, input) {
+  const now = new Date().toISOString();
+  return {
+    event_id: crypto.randomUUID(),
+    schema_version: '1.0.0',
+    event_name: eventName,
+    event_ts_utc: now,
+    client_ts: now,
+    source_system: 'field_app',
+    project_id: 'purpulse.app',
+    device_id: input.device_id ?? null,
+    session_id: input.session_id ?? null,
+    job_id: input.job_id,
+    dispatch_id: input.dispatch_id ?? null,
+    technician_id: input.technician_id || input.reviewer_id || 'unknown',
+    site_id: input.site_id ?? null,
+    connectivity_state: navigator.onLine ? 'online' : 'offline',
+    telemetry_consent: input.telemetry_consent ?? { location: false, device: true },
+    location: input.telemetry_consent?.location ? (input.location ?? null) : null,
+  };
+}
+
+async function send(path, payload) {
+  if (!navigator.onLine) {
+    queueTelemetry(path, payload);
+    return { status: 'queued', event_id: payload.event_id };
+  }
+
+  try {
+    return await postTelemetry(path, payload, { deviceId: payload.device_id });
+  } catch (error) {
+    queueTelemetry(path, payload);
+    return { status: 'queued', event_id: payload.event_id, error: error.message };
+  }
+}
+
+export function emitArtifactEvent(input) {
+  const payload = {
+    ...baseEnvelope('artifact_event', input),
+    artifact_id: input.artifact_id,
+    evidence_type: input.evidence_type,
+    captured_at: input.captured_at,
+    content_type: input.content_type,
+    size_bytes: input.size_bytes,
+    runbook_step_id: input.runbook_step_id ?? null,
+    documentation_artifact_id: input.documentation_artifact_id ?? input.artifact_id,
+    serial_value: input.serial_value ?? null,
+    asset_tag_capture_flag: !!input.asset_tag_capture_flag,
+    photo_uploaded_count: input.photo_uploaded_count ?? null,
+    photo_required_count: input.photo_required_count ?? null,
+    customer_signature_flag: !!input.customer_signature_flag,
+  };
+  return send('/api/v1/telemetry/artifact-events', payload);
+}
+
+export function emitQcEvent(input) {
+  const payload = {
+    ...baseEnvelope('qc_event', input),
+    artifact_id: input.artifact_id,
+    qc_task_id: input.qc_task_id ?? null,
+    reviewer_id: input.reviewer_id,
+    review_timestamp: input.review_timestamp ?? new Date().toISOString(),
+    validation_result: input.validation_result,
+    confidence: input.confidence ?? null,
+    bbox: input.bbox ?? null,
+    approved_for_training: input.approved_for_training ?? null,
+    defect_flag: input.validation_result === 'rejected',
+    retest_flag: !!input.retest_flag,
+  };
+  return send('/api/v1/telemetry/qc-events', payload);
+}
