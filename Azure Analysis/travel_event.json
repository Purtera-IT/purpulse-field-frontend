{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "travel_event",
  "description": "Canonical travel_event for core.fact_travel_event (Iteration 4 baseline — timestamps first, no geofence samples).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "schema_version",
    "event_name",
    "event_ts_utc",
    "client_ts",
    "source_system",
    "job_id",
    "technician_id"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "event_name": { "const": "travel_event" },
    "event_ts_utc": { "type": "string", "format": "date-time" },
    "client_ts": { "type": "string", "format": "date-time" },
    "source_system": { "const": "field_app" },
    "project_id": { "type": ["string", "null"] },
    "device_id": { "type": ["string", "null"] },
    "session_id": { "type": ["string", "null"] },
    "job_id": { "type": "string" },
    "dispatch_id": { "type": ["string", "null"] },
    "technician_id": { "type": "string" },
    "site_id": { "type": ["string", "null"] },
    "connectivity_state": {
      "type": ["string", "null"],
      "enum": ["offline", "cellular", "wifi", "unknown", null]
    },
    "telemetry_consent": {
      "type": "object",
      "required": ["location", "device"],
      "additionalProperties": false,
      "properties": {
        "location": { "type": "boolean" },
        "device": { "type": "boolean" }
      }
    },
    "location": { "type": ["object", "null"] },
    "route_departure_timestamp": { "type": ["string", "null"], "format": "date-time" },
    "geofence_arrival_timestamp": {
      "description": "Iteration 4: used as travel-segment end timestamp when geofence UX is absent.",
      "type": ["string", "null"],
      "format": "date-time"
    },
    "travel_minutes": { "type": ["number", "null"] },
    "planned_eta_timestamp": { "type": ["string", "null"], "format": "date-time" },
    "eta_ack_timestamp": { "type": ["string", "null"], "format": "date-time" },
    "eta_update_timestamp": { "type": ["string", "null"], "format": "date-time" },
    "location_consent_state": { "type": ["string", "null"] },
    "location_precise_allowed": { "type": ["boolean", "null"] }
  }
}
