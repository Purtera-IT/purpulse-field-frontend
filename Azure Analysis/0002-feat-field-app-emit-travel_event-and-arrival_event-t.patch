+++ b/src/lib/telemetry/travelArrivalEvents.js
@@ -0,0 +1,68 @@
+
+import { postTelemetry, queueTelemetry } from './ingestionClient';
+
+function baseEnvelope(input, eventName) {
+  const now = input.timestamp || new Date().toISOString();
+  return {
+    event_id: crypto.randomUUID(),
+    schema_version: '1.0.0',
+    event_name: eventName,
+    event_ts_utc: now,
+    client_ts: now,
+    source_system: 'field_app',
+    project_id: 'purpulse.app',
+    device_id: input.device_id ?? null,
+    session_id: input.session_id ?? null,
+    job_id: input.job_id,
+    dispatch_id: input.dispatch_id ?? null,
+    technician_id: input.technician_id || 'unknown',
+    site_id: input.site_id ?? null,
+    connectivity_state: navigator.onLine ? 'online' : 'offline',
+    telemetry_consent: input.telemetry_consent ?? { location: false, device: true },
+    location: input.telemetry_consent?.location ? (input.location ?? null) : null,
+  };
+}
+
+async function send(path, payload) {
+  if (!navigator.onLine) {
+    queueTelemetry(path, payload);
+    return { status: 'queued', event_id: payload.event_id };
+  }
+
+  try {
+    return await postTelemetry(path, payload, { deviceId: payload.device_id });
+  } catch (error) {
+    queueTelemetry(path, payload);
+    return { status: 'queued', event_id: payload.event_id, error: error.message };
+  }
+}
+
+export function buildTravelEvent(input) {
+  return {
+    ...baseEnvelope(input, 'travel_event'),
+    route_departure_timestamp: input.entry_type === 'travel_start' ? input.timestamp : null,
+    geofence_arrival_timestamp: input.entry_type === 'travel_end' ? input.timestamp : null,
+    travel_minutes: input.travel_minutes ?? null,
+    planned_eta_timestamp: input.planned_eta_timestamp ?? null,
+    eta_ack_timestamp: input.eta_ack_timestamp ?? null,
+    eta_update_timestamp: input.eta_update_timestamp ?? null,
+  };
+}
+
+export function buildArrivalEvent(input) {
+  return {
+    ...baseEnvelope(input, 'arrival_event'),
+    checkin_timestamp: input.entry_type === 'travel_end' ? input.timestamp : null,
+    geofence_arrival_timestamp: input.entry_type === 'travel_end' ? input.timestamp : null,
+    work_start_timestamp: input.entry_type === 'work_start' ? input.timestamp : null,
+    access_granted_timestamp: input.access_granted_timestamp ?? null,
+  };
+}
+
+export function emitTravelEvent(input) {
+  return send('/api/v1/telemetry/travel-events', buildTravelEvent(input));
+}
+
+export function emitArrivalEvent(input) {
+  return send('/api/v1/telemetry/arrival-events', buildArrivalEvent(input));
+}
