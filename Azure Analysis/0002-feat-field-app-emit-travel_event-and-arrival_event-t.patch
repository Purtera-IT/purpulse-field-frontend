+import { buildTravelEvent, buildArrivalEvent } from '@/lib/telemetry/travelArrivalEvents';
+
+describe('travel/arrival event builders', () => {
+  test('travel_start maps to route_departure_timestamp', () => {
+    const payload = buildTravelEvent({ job_id: 'job_1', technician_id: 'tech_1', entry_type: 'travel_start', timestamp: '2026-03-18T13:25:00.000Z' });
+    expect(payload.route_departure_timestamp).toBe('2026-03-18T13:25:00.000Z');
+  });
+
+  test('travel_end can become arrival event', () => {
+    const payload = buildArrivalEvent({ job_id: 'job_1', technician_id: 'tech_1', entry_type: 'travel_end', timestamp: '2026-03-18T14:03:00.000Z' });
