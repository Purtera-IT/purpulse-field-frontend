@@ -0,0 +1,18 @@
+
+export default async function handler(req: Request): Promise<Response> {
+  const payload = await req.json();
+  const route = payload?.event_name === 'arrival_event' ? 'core.fact_arrival_event' : 'core.fact_travel_event';
+
+  if (!payload?.event_id || !payload?.job_id || !payload?.technician_id) {
+    return new Response(JSON.stringify({ status: 'invalid' }), { status: 400, headers: { 'Content-Type': 'application/json' } });
+  }
+
+  return new Response(JSON.stringify({
+    status: 'accepted',
+    event_id: payload.event_id,
+    azure_target_table: route,
+  }), {
+    status: 202,
+    headers: { 'Content-Type': 'application/json' },
+  });
+}
