diff --git a/src/lib/telemetry/dispatchEvent.js b/src/lib/telemetry/dispatchEvent.js
new file mode 100644
index 0000000..a2a5310
--- /dev/null
+++ b/src/lib/telemetry/dispatchEvent.js
@@ -0,0 +1,77 @@
+
+import { postTelemetry, queueTelemetry } from './ingestionClient';
+
+function resolveTechnicianId(currentUser) {
+  return currentUser?.technician_id || currentUser?.id || currentUser?.email || 'unknown';
+}
+
+function buildLocation(location, consent) {
+  if (!consent?.location) return null;
+  if (!location) return null;
+  return {
+    lat: location.lat,
+    lon: location.lon,
+    accuracy_m: location.accuracy_m ?? null,
+  };
+}
+
+export function buildDispatchEvent({
+  job,
+  currentUser,
+  dispatchStatus,
+  dispatchAction,
+  sessionId,
+  deviceId,
+  connectivityState = navigator.onLine ? 'online' : 'offline',
+  location = null,
+  consent = { location: false, device: true },
+}) {
+  const now = new Date().toISOString();
+  const scheduledStart = job?.scheduled_date && job?.scheduled_time
+    ? new Date(`${job.scheduled_date}T${job.scheduled_time}`).toISOString()
+    : null;
+
+  return {
+    event_id: crypto.randomUUID(),
+    schema_version: '1.0.0',
+    event_name: 'dispatch_event',
+    event_ts_utc: now,
+    client_ts: now,
+    source_system: 'field_app',
+    project_id: 'purpulse.app',
+    session_id: sessionId ?? null,
+    device_id: consent?.device ? (deviceId ?? null) : null,
+    job_id: job.id,
+    dispatch_id: job.dispatch_id ?? null,
+    assignment_id: job.assignment_id ?? null,
+    technician_id: resolveTechnicianId(currentUser),
+    site_id: job.site_id ?? null,
+    status: dispatchStatus,
+    dispatch_action: dispatchAction,
+    scheduled_start_timestamp: scheduledStart,
+    connectivity_state: connectivityState,
+    telemetry_consent: {
+      location: !!consent?.location,
+      device: consent?.device !== false,
+    },
+    location: buildLocation(location, consent),
+  };
+}
+
+export async function emitDispatchEvent(input, options = {}) {
+  const payload = buildDispatchEvent(input);
+  if (!navigator.onLine) {
+    queueTelemetry('/api/v1/telemetry/dispatch-events', payload);
+    return { status: 'queued', event_id: payload.event_id };
+  }
+
+  try {
+    return await postTelemetry('/api/v1/telemetry/dispatch-events', payload, {
+      accessToken: options.accessToken,
+      deviceId: payload.device_id,
+    });
+  } catch (error) {
+    queueTelemetry('/api/v1/telemetry/dispatch-events', payload);
+    return { status: 'queued', event_id: payload.event_id, error: error.message };
+  }
+}
diff --git a/src/lib/telemetry/ingestionClient.js b/src/lib/telemetry/ingestionClient.js
new file mode 100644
index 0000000..e5d484a
--- /dev/null
+++ b/src/lib/telemetry/ingestionClient.js
@@ -0,0 +1,70 @@
+
+const QUEUE_KEY = 'purpulse_canonical_telemetry_queue';
+
+function loadQueue() {
+  try {
+    return JSON.parse(localStorage.getItem(QUEUE_KEY) || '[]');
+  } catch {
+    return [];
+  }
+}
+
+function saveQueue(queue) {
+  localStorage.setItem(QUEUE_KEY, JSON.stringify(queue));
+}
+
+export function queueTelemetry(path, payload) {
+  const queue = loadQueue();
+  queue.push({
+    event_id: payload.event_id,
+    path,
+    payload,
+    status: 'pending',
+    retry_count: 0,
+    queued_at: new Date().toISOString(),
+  });
+  saveQueue(queue);
+  return payload;
+}
+
+export async function postTelemetry(path, payload, options = {}) {
+  const baseUrl = import.meta.env.VITE_CANONICAL_INGEST_BASE_URL || '';
+  const response = await fetch(`${baseUrl}${path}`, {
+    method: 'POST',
+    headers: {
+      'Content-Type': 'application/json',
+      Authorization: options.accessToken ? `Bearer ${options.accessToken}` : '',
+      'X-Client-Request-ID': payload.event_id,
+      ...(options.deviceId ? { 'X-Device-ID': options.deviceId } : {}),
+    },
+    body: JSON.stringify(payload),
+  });
+
+  if (!response.ok && response.status !== 200 && response.status !== 202) {
+    const text = await response.text();
+    throw new Error(`Telemetry ingest failed (${response.status}): ${text}`);
+  }
+
+  return response.json().catch(() => ({ status: 'accepted' }));
+}
+
+export async function flushTelemetryQueue(options = {}) {
+  const pending = loadQueue();
+  const next = [];
+
+  for (const item of pending) {
+    try {
+      await postTelemetry(item.path, item.payload, options);
+    } catch (error) {
+      next.push({
+        ...item,
+        status: 'failed',
+        retry_count: (item.retry_count || 0) + 1,
+        last_error: error.message,
+      });
+    }
+  }
+
+  saveQueue(next);
+  return { attempted: pending.length, remaining: next.length };
+}
