new file mode 100644
index 0000000..a7c5bb3
--- /dev/null
+++ b/functions/ingestDispatchEvent.ts
@@ -0,0 +1,32 @@
+
+export default async function handler(req: Request): Promise<Response> {
+  const payload = await req.json();
+
+  if (!payload?.event_id || !payload?.job_id || !payload?.technician_id) {
+    return new Response(JSON.stringify({ status: 'invalid', error: 'event_id, job_id and technician_id are required' }), {
+      status: 400,
+      headers: { 'Content-Type': 'application/json' },
+    });
+  }
+
+  const enriched = {
+    ...payload,
+    ingest_received_utc: new Date().toISOString(),
+    azure_target_table: 'core.fact_dispatch_event',
+  };
+
+  // TODO: replace this stub with:
+  // 1) JWT validation / createClientFromRequest(req)
+  // 2) idempotency lookup by event_id
+  // 3) write to Azure Event Hubs / Service Bus / ADLS landing zone
+  // 4) write audit / AppInsights telemetry
+
+  return new Response(JSON.stringify({
+    status: 'accepted',
+    event_id: enriched.event_id,
+    azure_target_table: enriched.azure_target_table,
+  }), {
+    status: 202,
+    headers: { 'Content-Type': 'application/json' },
+  });
+}
